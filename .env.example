# ============================================
# TaskFlow — Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values.
# cp .env.example .env

# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/taskflow?schema=public

# JWT Secrets (CHANGE THESE IN PRODUCTION)
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_minimum_32_chars
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_minimum_32_chars
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_GLOBAL=100

# Logging
LOG_LEVEL=info
LOG_DIR=logs
